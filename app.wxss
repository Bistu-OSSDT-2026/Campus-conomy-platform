/* ========================================
   CampusMarket 全局样式
   主色 #2F6BFF  背景 #F5F7FB  卡片 #FFFFFF
   ======================================== */

page {
  --primary: #2F6BFF;
  --primary-light: #E8F0FF;
  --primary-dark: #1A5AE0;
  --danger: #FF4D4F;
  --success: #52C41A;
  --warning: #FAAD14;
  --text-primary: #1A1A2E;
  --text-secondary: #666666;
  --text-hint: #999999;
  --bg: #F5F7FB;
  --bg-white: #FFFFFF;
  --border: #E8ECF1;
  --shadow: 0 2px 12px rgba(0,0,0,0.08);

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  padding-bottom: 20rpx;
}

/* 卡片样式 */
.card {
  background: var(--bg-white);
  border-radius: 24rpx;
  margin: 20rpx 24rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #2F6BFF, #4D8BFF);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 48rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}
.btn-outline:active {
  background: var(--primary-light);
}

.btn-danger {
  background: var(--danger);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}
.btn-danger:active {
  opacity: 0.9;
}

.btn-sm {
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  border-radius: 32rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tag-primary {
  background: var(--primary-light);
  color: var(--primary);
}
.tag-danger {
  background: #FFF1F0;
  color: var(--danger);
}
.tag-success {
  background: #F6FFED;
  color: var(--success);
}
.tag-warning {
  background: #FFFBE6;
  color: #D48806;
}

/* 价格样式 */
.price {
  color: #FF4D4F;
  font-weight: 700;
}
.price-symbol {
  font-size: 24rpx;
}
.price-value {
  font-size: 36rpx;
}
.price-original {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 8rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}
.empty-state .empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.empty-state .empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-hint);
  font-size: 24rpx;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
