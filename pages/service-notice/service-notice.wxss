.page{background:#F5F7FB;min-height:100vh;padding:20rpx 24rpx}
.cat-scroll{white-space:nowrap;margin-bottom:20rpx;padding:4rpx 0}
.cat-tag{display:inline-block;padding:14rpx 28rpx;border-radius:12rpx;font-size:26rpx;color:#666;background:#FFF;margin-right:16rpx}
.cat-tag.active{background:#2F6BFF;color:#FFF}
.card{background:#FFF;border-radius:24rpx;padding:24rpx;margin-bottom:16rpx}
.notice-header{margin-bottom:12rpx}
.notice-line{display:flex;align-items:center;margin-bottom:8rpx}
.notice-title{font-size:28rpx;font-weight:600;color:#1A1A2E;flex:1;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;line-height:1.4}
.notice-important{font-size:20rpx;color:#FFF;background:#FF4D4F;padding:2rpx 12rpx;border-radius:8rpx;margin-left:12rpx;flex-shrink:0}
.notice-meta{display:flex;gap:16rpx;font-size:22rpx;color:#999}
.notice-summary{font-size:24rpx;color:#888;line-height:1.5;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.empty-msg{text-align:center;padding:80rpx 0}
.empty-text{font-size:26rpx;color:#999}
.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);z-index:200}
.modal-card{position:fixed;top:10%;left:24rpx;right:24rpx;bottom:10%;background:#FFF;border-radius:32rpx;padding:40rpx 32rpx;z-index:201;overflow-y:auto;animation:slideIn 0.3s}
@keyframes slideIn{from{opacity:0;transform:scale(0.95)}to{opacity:1;transform:scale(1)}}
.modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16rpx}
.modal-cat-tag{font-size:22rpx;color:#FF4D4F}
.modal-time{font-size:22rpx;color:#999}
.modal-title{font-size:32rpx;font-weight:700;color:#1A1A2E;margin-bottom:24rpx;line-height:1.5}
.modal-body{font-size:28rpx;color:#555;line-height:1.8}
.modal-close{text-align:center;font-size:28rpx;color:#2F6BFF;margin-top:24rpx;padding:16rpx 0}
.service-note{font-size:22rpx;color:#BBB;text-align:center;margin-top:10rpx;margin-bottom:20rpx}
.safe-bottom{height:40rpx}
