.detail-page {
  min-height: 100vh;
  background: #F5F7FB;
}

/* 状态横幅 */
.status-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
}

.status-banner.pending {
  background: linear-gradient(135deg, #FFFBE6, #FFF7D1);
}

.status-banner.confirmed {
  background: linear-gradient(135deg, #E8F0FF, #D6E4FF);
}

.status-banner.completed {
  background: linear-gradient(135deg, #F6FFED, #E6FFD8);
}

.status-banner.cancelled {
  background: linear-gradient(135deg, #F5F7FB, #EDEFF2);
}

.status-icon {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
}

/* 信息卡片 */
.section-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F5F7FB;
}

/* 商品行 */
.goods-row {
  display: flex;
}

.goods-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.goods-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
}

.goods-cat {
  font-size: 22rpx;
  color: #2F6BFF;
  background: #EEF3FF;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  align-self: flex-start;
}

.goods-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF4D4F;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F5F7FB;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  word-break: break-all;
}

.info-value.mono {
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  color: #666;
}

/* 操作按钮 */
.action-section {
  padding: 24rpx;
}

.btn-danger {
  background: #FF4D4F;
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
