.home-page {
  background: #F5F7FB;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
}
.search-box {
  display: flex;
  align-items: center;
  background: #F5F7FB;
  border-radius: 48rpx;
  padding: 18rpx 28rpx;
}
.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}
.search-placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 横幅 */
.banner-section {
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}
.banner-card {
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.banner-content {
  flex: 1;
}
.banner-tag {
  display: inline-block;
  background: rgba(255,255,255,0.3);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}
.banner-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}
.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}
.banner-img {
  font-size: 80rpx;
}

/* ==================== 滑动广告位 ==================== */
.ad-section {
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.ad-swiper {
  width: 100%;
  height: 160rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

/* 广告卡片 */
.ad-card {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.ad-card:active {
  opacity: 0.92;
}

/* 左侧内容 */
.ad-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

/* 标签 */
.ad-tag {
  display: inline-block;
  width: fit-content;
  background: rgba(255,255,255,0.28);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

/* 标题 */
.ad-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

/* 副标题 */
.ad-subtitle {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 10rpx;
}

/* 按钮 */
.ad-btn {
  display: inline-block;
  width: fit-content;
  background: rgba(255,255,255,0.92);
  color: #333;
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 24rpx;
  border-radius: 24rpx;
}

/* 右侧图标（半透明圆形底衬） */
.ad-icon {
  width: 110rpx;
  height: 110rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
  background: rgba(255,255,255,0.22);
  border-radius: 50%;
}

/* ===== 四条广告不同渐变背景 ===== */
.ad-blue {
  background: linear-gradient(135deg, #4A6CF7, #6B8AFF);
}

.ad-milkTea {
  background: linear-gradient(135deg, #F5A623, #FADB8E);
}

.ad-cyan {
  background: linear-gradient(135deg, #1E3A5F, #2C6B9E);
}

.ad-green {
  background: linear-gradient(135deg, #4CAF50, #6ECB70);
}

/* ===== 校园服务入口 ===== */
.service-section {
  background: #FFFFFF;
  margin: 0 24rpx 16rpx;
  border-radius: 24rpx;
  padding: 24rpx 16rpx 16rpx;
}

.service-grid {
  display: flex;
  flex-wrap: wrap;
}

.service-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 0;
}

.service-item:active {
  opacity: 0.7;
}

.service-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #E8F0FE, #F0F5FF);
  margin-bottom: 8rpx;
}

.service-icon {
  font-size: 38rpx;
}

.service-name {
  font-size: 22rpx;
  color: #555;
  text-align: center;
}

.service-hint {
  text-align: center;
  font-size: 20rpx;
  color: #BBB;
  margin-top: 8rpx;
}

/* 公告 */
.notice-section {
  background: #FFFFFF;
  margin: 0 24rpx 16rpx;
  border-radius: 24rpx;
  padding: 24rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
}
.section-more {
  font-size: 26rpx;
  color: #999;
}
.notice-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F5F7FB;
}
.notice-item:last-child {
  border-bottom: none;
}
.notice-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.notice-dot.hot { background: #FF4D4F; }
.notice-dot.notice { background: #2F6BFF; }
.notice-dot.activity { background: #52C41A; }
.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.notice-date {
  font-size: 22rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 商品列表 */
.goods-section {
  padding: 0 24rpx;
}
.goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.goods-card {
  width: calc(50% - 12rpx);
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  transition: transform 0.2s;
}
.goods-card:active {
  transform: scale(0.98);
}

/* 商品图片 */
.goods-img-wrap {
  width: 100%;
  height: 280rpx;
  position: relative;
  overflow: hidden;
}
.goods-img {
  width: 100%;
  height: 100%;
}
.goods-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(47,107,255,0.9);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 商品信息 */
.goods-info {
  padding: 16rpx 20rpx;
}
.goods-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
  margin-bottom: 8rpx;
}
.goods-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 12rpx;
}
.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.goods-price {
  display: flex;
  align-items: baseline;
}
.price-symbol {
  font-size: 22rpx;
  color: #FF4D4F;
  font-weight: 600;
}
.price-value {
  font-size: 34rpx;
  color: #FF4D4F;
  font-weight: 700;
}
.price-original {
  font-size: 20rpx;
  color: #CCC;
  text-decoration: line-through;
  margin-left: 6rpx;
}
.goods-meta {
  font-size: 20rpx;
  color: #BBB;
}

/* 卖家 */
.seller-row {
  display: flex;
  align-items: center;
  border-top: 1rpx solid #F5F7FB;
  padding-top: 12rpx;
}
.seller-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}
.seller-name {
  font-size: 22rpx;
  color: #666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.seller-verified {
  font-size: 20rpx;
  color: #52C41A;
  background: #F6FFED;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
}
.goods-time {
  font-size: 20rpx;
  color: #BBB;
}
