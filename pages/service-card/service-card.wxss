.page{background:#F5F7FB;min-height:100vh;padding:20rpx 24rpx}
.balance-card{background:linear-gradient(135deg,#2F6BFF,#4A6CF7);border-radius:24rpx;padding:36rpx 32rpx;margin-bottom:24rpx;color:#FFF}
.balance-label{font-size:26rpx;opacity:0.85;margin-bottom:8rpx}
.balance-amount{font-size:60rpx;font-weight:700;margin-bottom:16rpx}
.balance-info{display:flex;gap:32rpx;font-size:24rpx;opacity:0.8}
.menu-grid{display:flex;background:#FFF;border-radius:24rpx;padding:8rpx 0;margin-bottom:24rpx}
.menu-item{width:25%;display:flex;flex-direction:column;align-items:center;padding:20rpx 0}
.menu-item:active{opacity:0.7}
.menu-icon-wrap{width:80rpx;height:80rpx;border-radius:20rpx;display:flex;align-items:center;justify-content:center;font-size:36rpx;margin-bottom:8rpx}
.menu-icon-wrap.blue{background:#E8F0FE}
.menu-icon-wrap.green{background:#E8F5E9}
.menu-icon-wrap.orange{background:#FFF3E0}
.menu-icon-wrap.purple{background:#F3E5F5}
.menu-label{font-size:24rpx;color:#555}
.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);z-index:200}
.modal-card{position:fixed;bottom:0;left:0;right:0;background:#FFF;border-radius:32rpx 32rpx 0 0;padding:40rpx 32rpx;z-index:201;animation:slideUp .3s;max-height:70vh;overflow-y:auto}
.records-modal{max-height:60vh}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-title{font-size:32rpx;font-weight:700;color:#1A1A2E;margin-bottom:24rpx;text-align:center}
.bill-row{display:flex;justify-content:space-between;padding:16rpx 0;border-bottom:1rpx solid #F0F0F0}
.bill-label{font-size:26rpx;color:#999}
.bill-value{font-size:26rpx;color:#333;font-weight:500}
.recharge-input{background:#F5F7FB;border-radius:16rpx;padding:24rpx;font-size:30rpx;text-align:center;margin-bottom:20rpx}
.quick-amounts{display:flex;gap:16rpx;margin-bottom:24rpx}
.amount-tag{flex:1;text-align:center;padding:16rpx 0;border-radius:12rpx;font-size:26rpx;color:#2F6BFF;background:#F0F5FF}
.amount-tag:active{background:#D6E4FF}
.btn-primary{width:100%;background:linear-gradient(135deg,#4A6CF7,#2F6BFF);color:#FFF;border-radius:16rpx;font-size:30rpx;font-weight:600;padding:24rpx 0;border:none;margin-bottom:12rpx}
.btn-primary::after{border:none}
.record-item{display:flex;justify-content:space-between;align-items:center;padding:20rpx 0;border-bottom:1rpx solid #F0F0F0}
.rec-left{flex:1}
.rec-name{font-size:28rpx;color:#333;margin-bottom:4rpx}
.rec-time{font-size:22rpx;color:#999}
.rec-right{text-align:right}
.rec-type{font-size:22rpx;color:#2F6BFF;background:#F0F5FF;padding:2rpx 12rpx;border-radius:8rpx;display:inline-block;margin-bottom:4rpx}
.rec-amount{font-size:28rpx;color:#FF4D4F;font-weight:600;display:block}
.modal-close{text-align:center;font-size:26rpx;color:#999;margin-top:16rpx}
.service-note{font-size:22rpx;color:#BBB;text-align:center;margin-top:10rpx}
.safe-bottom{height:40rpx}
