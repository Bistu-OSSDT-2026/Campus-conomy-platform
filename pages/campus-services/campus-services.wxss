/* 页面基础样式 */
.page {
  background: #F5F7FB;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部标题区 */
.header {
  background: linear-gradient(135deg, #2F6BFF 0%, #5A8EFF 100%);
  padding: 40rpx 32rpx 48rpx;
  color: #FFF;
}
.header-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.header-subtitle {
  font-size: 24rpx;
  opacity: 0.85;
}

/* 快捷功能区 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  background: #FFF;
  padding: 32rpx 24rpx;
  margin: -24rpx 24rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 10;
}
.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.quick-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.quick-icon {
  font-size: 44rpx;
}
.quick-text {
  font-size: 24rpx;
  color: #666;
}

/* 区块通用样式 */
.section {
  padding: 0 24rpx 32rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0 20rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}
.section-more {
  font-size: 24rpx;
  color: #2F6BFF;
}

/* 服务卡片网格 */
.service-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.service-card {
  background: #FFF;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  position: relative;
  transition: transform 0.2s, box-shadow 0.2s;
}
.service-card:active {
  transform: scale(0.98);
  background: #F9FAFB;
}
.card-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  opacity: 0.9;
}
.card-icon {
  font-size: 40rpx;
}
.card-content {
  flex: 1;
  min-width: 0;
}
.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 6rpx;
}
.card-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-badge {
  position: absolute;
  top: 16rpx;
  right: 80rpx;
  background: #FF4757;
  color: #FFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}
.card-arrow {
  font-size: 40rpx;
  color: #CCC;
  flex-shrink: 0;
}

/* 通知列表 */
.notice-list {
  background: #FFF;
  border-radius: 24rpx;
  overflow: hidden;
}
.notice-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
  position: relative;
}
.notice-item:last-child {
  border-bottom: none;
}
.notice-tag {
  font-size: 20rpx;
  color: #666;
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.notice-tag.important {
  color: #FFF;
  background: #FF4757;
}
.notice-content {
  flex: 1;
  min-width: 0;
}
.notice-title {
  font-size: 26rpx;
  color: #1A1A2E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}
.notice-time {
  font-size: 22rpx;
  color: #999;
}
.notice-dot {
  width: 12rpx;
  height: 12rpx;
  background: #FF4757;
  border-radius: 50%;
  margin-left: 12rpx;
  flex-shrink: 0;
  animation: pulse 1.5s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 活动列表 */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.activity-card {
  background: #FFF;
  border-radius: 24rpx;
  padding: 24rpx;
  transition: transform 0.2s;
}
.activity-card:active {
  transform: scale(0.98);
}
.activity-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.activity-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  flex: 1;
  margin-right: 16rpx;
}
.activity-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.activity-tag.competition { background: #E8F0FE; color: #2F6BFF; }
.activity-tag.innovation { background: #FFF3E8; color: #F5A623; }
.activity-tag.culture { background: #E8F5E9; color: #51CF66; }
.activity-tag.volunteer { background: #FCE4EC; color: #E91E63; }
.activity-tag.lecture { background: #F3E5F5; color: #9C27B0; }

.activity-info {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
}
.activity-info-item {
  font-size: 24rpx;
  color: #666;
}
.activity-deadline {
  display: flex;
  align-items: center;
}
.deadline-label {
  font-size: 22rpx;
  color: #999;
}
.deadline-value {
  font-size: 22rpx;
  color: #51CF66;
}
.deadline-value.near {
  color: #FF4757;
  font-weight: 600;
}

/* 底部说明 */
.page-footer {
  padding: 32rpx 24rpx;
  text-align: center;
}
.footer-note {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.footer-tip {
  font-size: 20rpx;
  color: #BBB;
}

.safe-bottom {
  height: 40rpx;
}
