<view class="page">
  <!-- 顶部标题区 -->
  <view class="header">
    <view class="header-title">校园服务</view>
    <view class="header-subtitle">整合常用校园官方服务入口</view>
  </view>

  <!-- 快捷功能区 -->
  <view class="quick-actions">
    <view class="quick-item" bindtap="onQuickTap" data-action="scan">
      <view class="quick-icon-wrap" style="background: linear-gradient(135deg, #667EEA, #764BA2)">
        <text class="quick-icon">📱</text>
      </view>
      <text class="quick-text">一扫通</text>
    </view>
    <view class="quick-item" bindtap="onQuickTap" data-action="card">
      <view class="quick-icon-wrap" style="background: linear-gradient(135deg, #F093FB, #F5576C)">
        <text class="quick-icon">💳</text>
      </view>
      <text class="quick-text">校园卡</text>
    </view>
    <view class="quick-item" bindtap="onQuickTap" data-action="schedule">
      <view class="quick-icon-wrap" style="background: linear-gradient(135deg, #4FACFE, #00F2FE)">
        <text class="quick-icon">📅</text>
      </view>
      <text class="quick-text">课表</text>
    </view>
    <view class="quick-item" bindtap="onQuickTap" data-action="more">
      <view class="quick-icon-wrap" style="background: linear-gradient(135deg, #43E97B, #38F9D7)">
        <text class="quick-icon">➕</text>
      </view>
      <text class="quick-text">更多</text>
    </view>
  </view>

  <!-- 服务分类区 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📚 学习服务</text>
    </view>
    <view class="service-grid">
      <view class="service-card" wx:for="{{studyServices}}" wx:key="id" bindtap="onServiceTap" data-item="{{item}}">
        <view class="card-icon-wrap" style="background: {{item.bgColor}}">
          <text class="card-icon">{{item.icon}}</text>
        </view>
        <view class="card-content">
          <view class="card-name">{{item.name}}</view>
          <view class="card-desc">{{item.desc}}</view>
        </view>
        <view class="card-badge" wx:if="{{item.badge}}">{{item.badge}}</view>
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">🏠 生活服务</text>
    </view>
    <view class="service-grid">
      <view class="service-card" wx:for="{{lifeServices}}" wx:key="id" bindtap="onServiceTap" data-item="{{item}}">
        <view class="card-icon-wrap" style="background: {{item.bgColor}}">
          <text class="card-icon">{{item.icon}}</text>
        </view>
        <view class="card-content">
          <view class="card-name">{{item.name}}</view>
          <view class="card-desc">{{item.desc}}</view>
        </view>
        <view class="card-badge" wx:if="{{item.badge}}">{{item.badge}}</view>
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">🔔 通知公告</text>
      <view class="section-more" bindtap="onMoreNotice">查看更多 ›</view>
    </view>
    <view class="notice-list">
      <view class="notice-item" wx:for="{{recentNotices}}" wx:key="id" bindtap="onNoticeTap" data-notice="{{item}}">
        <view class="notice-tag {{item.important ? 'important' : ''}}">{{item.categoryName}}</view>
        <view class="notice-content">
          <view class="notice-title">{{item.title}}</view>
          <view class="notice-time">{{item.time}}</view>
        </view>
        <view class="notice-dot" wx:if="{{item.important}}"></view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">🏆 活动赛事</text>
      <view class="section-more" bindtap="onMoreActivity">查看更多 ›</view>
    </view>
    <view class="activity-list">
      <view class="activity-card" wx:for="{{recentActivities}}" wx:key="id" bindtap="onActivityTap" data-activity="{{item}}">
        <view class="activity-header">
          <text class="activity-name">{{item.name}}</text>
          <text class="activity-tag {{item.category}}">{{item.categoryName}}</text>
        </view>
        <view class="activity-info">
          <text class="activity-info-item">📍 {{item.place}}</text>
          <text class="activity-info-item">👥 {{item.participants}}人参与</text>
        </view>
        <view class="activity-deadline">
          <text class="deadline-label">报名截止：</text>
          <text class="deadline-value {{item.deadlineNear ? 'near' : ''}}">{{item.deadline}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="page-footer">
    <view class="footer-note">数据来源：学校官方平台</view>
    <view class="footer-tip">如有疑问请联系 campus@university.edu.cn</view>
  </view>
  <view class="safe-bottom"></view>
</view>
