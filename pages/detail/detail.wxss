.detail-page {
  background: #F5F7FB;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  height: 600rpx;
}
.swiper-image {
  width: 100%;
  height: 100%;
}

/* 价格标题 */
.info-header {
  background: #FFFFFF;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}
.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.price-main {
  display: flex;
  align-items: baseline;
}
.price-symbol {
  font-size: 28rpx;
  color: #FF4D4F;
  font-weight: 600;
}
.price-value {
  font-size: 48rpx;
  color: #FF4D4F;
  font-weight: 700;
  line-height: 1;
}
.price-original {
  font-size: 26rpx;
  color: #CCC;
  text-decoration: line-through;
  margin-left: 16rpx;
}
.goods-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  line-height: 1.5;
  margin-bottom: 16rpx;
}
.goods-tags {
  display: flex;
  gap: 12rpx;
}

/* 卖家信息 */
.seller-card {
  background: #FFFFFF;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}
.seller-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}
.seller-info {
  flex: 1;
}
.seller-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 6rpx;
}
.verified-badge {
  font-size: 22rpx;
  color: #52C41A;
  background: #F6FFED;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
}
.seller-school {
  font-size: 24rpx;
  color: #999;
}
.contact-btn {
  background: #E8F0FF;
  color: #2F6BFF;
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border-radius: 48rpx;
  font-weight: 500;
}

/* 描述 */
.desc-section {
  background: #FFFFFF;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F5F7FB;
}
.desc-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 交易信息 */
.info-section {
  background: #FFFFFF;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F7FB;
}
.info-row:last-child {
  border-bottom: none;
}
.info-label {
  font-size: 26rpx;
  color: #999;
}
.info-value {
  font-size: 26rpx;
  color: #333;
}

/* 举报 */
.report-section {
  text-align: center;
  padding: 28rpx;
}
.report-link {
  font-size: 26rpx;
  color: #FF4D4F;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.bar-left {
  display: flex;
  margin-right: 20rpx;
}
.bar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 20rpx;
}
.bar-btn.active .bar-text {
  color: #FF4D4F;
}
.bar-icon {
  font-size: 36rpx;
  margin-bottom: 2rpx;
}
.bar-text {
  font-size: 20rpx;
  color: #999;
}
.bar-num {
  font-size: 20rpx;
  color: #CCC;
}
.bar-right {
  flex: 1;
  display: flex;
  gap: 16rpx;
}
.contact-main-btn {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #2F6BFF, #4D8BFF);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.contact-main-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
}
.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  z-index: 201;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A2E;
  text-align: center;
  margin-bottom: 28rpx;
}
.modal-body {
  margin-bottom: 28rpx;
}
.contact-info {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F7FB;
}
.contact-label {
  font-size: 28rpx;
  color: #999;
  width: 160rpx;
}
.contact-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.contact-value.contact-hidden {
  color: #BBB;
  font-weight: 400;
}
.contact-tip {
  font-size: 24rpx;
  color: #FAAD14;
  margin-top: 16rpx;
  text-align: center;
}
.modal-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2F6BFF, #4D8BFF);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-actions {
  display: flex;
  gap: 20rpx;
}
.modal-actions .modal-btn {
  flex: 1;
}
.modal-actions .cancel {
  background: #F5F7FB;
  color: #666;
}

/* 举报原因 */
.report-reason-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.report-reason {
  padding: 24rpx;
  border-radius: 16rpx;
  background: #F5F7FB;
  font-size: 28rpx;
  color: #666;
  text-align: center;
}
.report-reason.active {
  background: #FFF1F0;
  color: #FF4D4F;
  border: 2rpx solid #FF4D4F;
}
