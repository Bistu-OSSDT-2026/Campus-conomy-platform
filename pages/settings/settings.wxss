.settings-page {
  min-height: 100vh;
  background: #F5F7FB;
}

.settings-section {
  background: #FFFFFF;
  margin: 0 24rpx 16rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 26rpx;
  color: #999;
  padding: 20rpx 28rpx 8rpx;
}

/* 头像行 */
.avatar-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F5F7FB;
}
.avatar-row:active {
  background: #F5F7FB;
}
.avatar-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}
.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #E8F0FF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* 输入行 */
.input-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F5F7FB;
}
.input-row:last-child {
  border-bottom: none;
}
.row-label {
  font-size: 28rpx;
  color: #333;
  width: 160rpx;
  flex-shrink: 0;
}
.row-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}
.row-input::placeholder {
  color: #CCC;
}

/* 设置项（可点击的picker行） */
.setting-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F5F7FB;
}
.setting-item:last-child {
  border-bottom: none;
}
.setting-item:active {
  background: #F5F7FB;
}
.row-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
.row-value {
  font-size: 28rpx;
  color: #333;
}
.row-value.placeholder {
  color: #CCC;
}
.row-hint {
  font-size: 24rpx;
  color: #BBB;
  margin-right: 8rpx;
}
.row-arrow {
  font-size: 32rpx;
  color: #CCC;
  font-weight: 300;
  margin-left: 4rpx;
}
.row-picker {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

/* 开关行 */
.switch-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F5F7FB;
}
.switch-row:last-child {
  border-bottom: none;
}

/* 保存按钮 */
.save-section {
  padding: 40rpx 24rpx;
}
.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2F6BFF, #4D8BFF);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.save-btn:active {
  opacity: 0.85;
}

/* ========== 弹窗通用 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
}
.modal-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.25s ease-out;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #F5F7FB;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 0 8rpx;
}

/* ========== 学校搜索弹窗 ========== */
.school-modal {
  min-height: 60vh;
}
.school-search-bar {
  padding: 16rpx 24rpx;
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F5F7FB;
  border-radius: 40rpx;
  padding: 12rpx 20rpx;
}
.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.search-clear {
  font-size: 28rpx;
  color: #BBB;
  padding: 0 12rpx;
}
.school-list {
  flex: 1;
  max-height: 50vh;
}
.school-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F5F7FB;
}
.school-item:active {
  background: #F5F7FB;
}
.school-item.active {
  background: #EEF3FF;
}
.school-name {
  font-size: 28rpx;
  color: #333;
}
.school-check {
  font-size: 28rpx;
  color: #2F6BFF;
  font-weight: 600;
}
.school-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #BBB;
  font-size: 28rpx;
}

/* ========== 修改密码弹窗 ========== */
.pwd-modal {
  min-height: auto;
  padding-bottom: env(safe-area-inset-bottom);
}
.pwd-form {
  padding: 16rpx 24rpx;
}
.pwd-row {
  display: flex;
  align-items: center;
  padding: 20rpx 8rpx;
  border-bottom: 1rpx solid #F5F7FB;
}
.pwd-row:last-child {
  border-bottom: none;
}
.pwd-label {
  font-size: 28rpx;
  color: #333;
  width: 180rpx;
  flex-shrink: 0;
}
.pwd-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}
.pwd-input::placeholder {
  color: #CCC;
}
.pwd-actions {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}
.pwd-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.pwd-btn.cancel {
  background: #F5F7FB;
  color: #666;
}
.pwd-btn.confirm {
  background: linear-gradient(135deg, #2F6BFF, #4D8BFF);
  color: #FFFFFF;
}
.pwd-btn:active {
  opacity: 0.85;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
  height: 40rpx;
}
