<view class="settings-page">
  <!-- ==================== 个人资料 ==================== -->
  <view class="settings-section">
    <view class="section-title">个人资料</view>

    <!-- 头像 -->
    <view class="avatar-row" bindtap="onChangeAvatar">
      <text class="row-label">头像</text>
      <view class="row-right">
        <image class="avatar-preview" src="{{avatarPreview}}" mode="aspectFill" wx:if="{{avatarPreview}}" />
        <view class="avatar-placeholder" wx:else>👤</view>
        <text class="row-arrow">›</text>
      </view>
    </view>

    <!-- 昵称 -->
    <view class="input-row">
      <text class="row-label">昵称</text>
      <input class="row-input" type="text" maxlength="12" placeholder="2-12个字符" value="{{nickname}}" bindinput="onNicknameInput" />
    </view>

    <!-- 联系方式 -->
    <view class="input-row">
      <text class="row-label">联系方式</text>
      <input class="row-input" type="text" placeholder="手机号/微信号" value="{{contact}}" bindinput="onContactInput" />
    </view>
  </view>

  <!-- ==================== 校园信息 ==================== -->
  <view class="settings-section">
    <view class="section-title">校园信息</view>

    <!-- 学校 -->
    <view class="setting-item" bindtap="onOpenSchoolPicker">
      <text class="row-label">学校</text>
      <view class="row-right">
        <text class="row-value {{school ? '' : 'placeholder'}}">{{school || '请选择学校'}}</text>
        <text class="row-arrow">›</text>
      </view>
    </view>

    <!-- 校区 -->
    <view class="setting-item">
      <text class="row-label">校区</text>
      <view class="row-right">
        <picker class="row-picker" mode="selector" range="{{campusList}}" value="{{campusIndex}}" bindchange="onCampusChange">
          <text class="row-value {{campus ? '' : 'placeholder'}}">{{campus || '请选择校区'}}</text>
          <text class="row-arrow">›</text>
        </picker>
      </view>
    </view>

    <!-- 年级 -->
    <view class="setting-item">
      <text class="row-label">年级</text>
      <view class="row-right">
        <picker class="row-picker" mode="selector" range="{{gradeList}}" value="{{gradeIndex}}" bindchange="onGradeChange">
          <text class="row-value {{grade ? '' : 'placeholder'}}">{{grade || '请选择年级'}}</text>
          <text class="row-arrow">›</text>
        </picker>
      </view>
    </view>

    <!-- 专业 -->
    <view class="input-row">
      <text class="row-label">专业</text>
      <input class="row-input" type="text" placeholder="请输入专业" value="{{major}}" bindinput="onMajorInput" />
    </view>
  </view>

  <!-- ==================== 修改密码 ==================== -->
  <view class="settings-section">
    <view class="setting-item" bindtap="onChangePassword">
      <text class="row-label">修改密码</text>
      <view class="row-right">
        <text class="row-hint">点击修改</text>
        <text class="row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- ==================== 隐私设置 ==================== -->
  <view class="settings-section">
    <view class="section-title">隐私设置</view>
    <view class="switch-row">
      <text class="row-label">公开联系方式</text>
      <switch checked="{{showContact}}" bindchange="onShowContactChange" color="#2F6BFF" />
    </view>
    <view class="switch-row">
      <text class="row-label">允许别人查看我的发布</text>
      <switch checked="{{showMyPosts}}" bindchange="onShowMyPostsChange" color="#2F6BFF" />
    </view>
    <view class="switch-row">
      <text class="row-label">允许平台进行校园身份风控核验</text>
      <switch checked="{{allowRiskCheck}}" bindchange="onAllowRiskCheckChange" color="#2F6BFF" />
    </view>
  </view>

  <!-- ==================== 通知设置 ==================== -->
  <view class="settings-section">
    <view class="section-title">通知设置</view>
    <view class="switch-row">
      <text class="row-label">接收系统通知</text>
      <switch checked="{{receiveNotify}}" bindchange="onReceiveNotifyChange" color="#2F6BFF" />
    </view>
    <view class="switch-row">
      <text class="row-label">接收交易提醒</text>
      <switch checked="{{receiveTradeNotify}}" bindchange="onReceiveTradeNotifyChange" color="#2F6BFF" />
    </view>
  </view>

  <!-- ==================== 保存按钮 ==================== -->
  <view class="save-section">
    <button class="save-btn" bindtap="onSave">保存设置</button>
  </view>

  <!-- ==================== 学校搜索弹窗 ==================== -->
  <view class="modal-mask" wx:if="{{showSchoolPicker}}" bindtap="onCloseSchoolPicker"></view>
  <view class="modal-content school-modal" wx:if="{{showSchoolPicker}}">
    <view class="modal-header">
      <text class="modal-title">选择学校</text>
      <text class="modal-close" bindtap="onCloseSchoolPicker">✕</text>
    </view>
    <view class="school-search-bar">
      <view class="search-input-wrap">
        <text class="search-icon">🔍</text>
        <input class="search-input" type="text" placeholder="搜索学校名称" value="{{schoolSearchKey}}" bindinput="onSchoolSearch" />
        <text class="search-clear" wx:if="{{schoolSearchKey}}" bindtap="onClearSchoolSearch">✕</text>
      </view>
    </view>
    <scroll-view class="school-list" scroll-y>
      <view
        class="school-item {{school === item.name ? 'active' : ''}}"
        wx:for="{{filteredSchoolList}}"
        wx:key="name"
        bindtap="onSelectSchool"
        data-name="{{item.name}}"
      >
        <text class="school-name">{{item.name}}</text>
        <text class="school-check" wx:if="{{school === item.name}}">✓</text>
      </view>
      <view class="school-empty" wx:if="{{filteredSchoolList.length === 0}}">
        <text>未找到匹配的学校</text>
      </view>
    </scroll-view>
  </view>

  <!-- ==================== 修改密码弹窗 ==================== -->
  <view class="modal-mask" wx:if="{{showPwdModal}}" bindtap="onClosePwdModal"></view>
  <view class="modal-content pwd-modal" wx:if="{{showPwdModal}}">
    <view class="modal-header">
      <text class="modal-title">修改密码</text>
      <text class="modal-close" bindtap="onClosePwdModal">✕</text>
    </view>
    <view class="pwd-form">
      <view class="pwd-row">
        <text class="pwd-label">原密码</text>
        <input class="pwd-input" type="password" placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onOldPwdInput" />
      </view>
      <view class="pwd-row">
        <text class="pwd-label">新密码</text>
        <input class="pwd-input" type="password" placeholder="至少6位" value="{{newPassword}}" bindinput="onNewPwdInput" />
      </view>
      <view class="pwd-row">
        <text class="pwd-label">确认新密码</text>
        <input class="pwd-input" type="password" placeholder="再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPwdInput" />
      </view>
    </view>
    <view class="pwd-actions">
      <button class="pwd-btn cancel" bindtap="onClosePwdModal">取消</button>
      <button class="pwd-btn confirm" bindtap="onSubmitPassword">确认修改</button>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
