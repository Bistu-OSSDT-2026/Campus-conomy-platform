.page{background:#F5F7FB;min-height:100vh;padding:20rpx 24rpx}
.card{background:#FFF;border-radius:24rpx;padding:24rpx;margin-bottom:20rpx}
.card-title{font-size:28rpx;font-weight:600;color:#1A1A2E;margin-bottom:16rpx}
.week-range{text-align:center;font-size:22rpx;color:#999;margin-top:8rpx}
.weekday-bar{display:flex;background:#FFF;border-radius:24rpx;margin-bottom:20rpx;overflow:hidden}
.weekday-item{flex:1;text-align:center;padding:20rpx 0;font-size:26rpx;color:#666}
.weekday-item.active{color:#2F6BFF;font-weight:700;background:#F0F5FF}
.course-card{background:#F9FAFB;border-radius:16rpx;padding:20rpx;margin-bottom:14rpx}
.course-card:active{opacity:0.8}
.course-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:12rpx}
.course-name{font-size:30rpx;font-weight:700;color:#1A1A2E}
.course-time{font-size:24rpx;color:#2F6BFF}
.course-info{display:flex;gap:20rpx;font-size:24rpx;color:#888}
.empty-msg{text-align:center;padding:60rpx 0}
.empty-icon{font-size:60rpx;display:block;margin-bottom:16rpx}
.empty-text{font-size:26rpx;color:#999}
.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);z-index:200}
.modal-card{position:fixed;bottom:0;left:0;right:0;background:#FFF;border-radius:32rpx 32rpx 0 0;padding:40rpx 32rpx;z-index:201;animation:slideUp 0.3s}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-title{font-size:32rpx;font-weight:700;color:#1A1A2E;margin-bottom:24rpx;text-align:center}
.d-row{display:flex;justify-content:space-between;padding:16rpx 0;border-bottom:1rpx solid #F0F0F0}
.d-label{font-size:26rpx;color:#999}
.d-value{font-size:26rpx;color:#333;font-weight:500}
.modal-close{text-align:center;font-size:26rpx;color:#999;margin-top:20rpx}
.service-note{font-size:22rpx;color:#BBB;text-align:center;margin-top:10rpx}
.safe-bottom{height:40rpx}
