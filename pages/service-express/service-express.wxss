.page{background:#F5F7FB;min-height:100vh;padding:20rpx 24rpx}
.card{background:#FFF;border-radius:24rpx;padding:24rpx;margin-bottom:20rpx}
.card-title{font-size:28rpx;font-weight:600;color:#1A1A2E;margin-bottom:16rpx}
.tag-row{display:flex;gap:16rpx}
.tag-row.wrap{flex-wrap:wrap}
.tag{padding:14rpx 24rpx;border-radius:12rpx;font-size:26rpx;color:#666;background:#F5F7FB}
.tag.active{background:#2F6BFF;color:#FFF}
.form-input{background:#F5F7FB;border-radius:16rpx;padding:20rpx 24rpx;font-size:28rpx;margin-bottom:16rpx}
.form-textarea{background:#F5F7FB;border-radius:16rpx;padding:20rpx 24rpx;font-size:28rpx;height:120rpx;margin-bottom:8rpx}
.price-info{display:flex;justify-content:space-between;align-items:center}
.price-desc{font-size:26rpx;color:#666}
.price-num{font-size:30rpx;color:#FF4D4F;font-weight:700}
.btn-primary{width:100%;background:linear-gradient(135deg,#4A6CF7,#2F6BFF);color:#FFF;border-radius:16rpx;font-size:30rpx;font-weight:600;padding:24rpx 0;border:none}
.btn-primary::after{border:none}
.result-card{background:#FFF;border-radius:24rpx;padding:40rpx 32rpx;text-align:center}
.result-icon{font-size:80rpx;margin-bottom:16rpx}
.result-title{font-size:34rpx;font-weight:700;color:#2E7D32;margin-bottom:8rpx}
.result-sub{font-size:26rpx;color:#FF922B;margin-bottom:24rpx}
.order-info{text-align:left;background:#F9FAFB;border-radius:16rpx;padding:20rpx}
.oi-row{display:flex;justify-content:space-between;padding:12rpx 0;border-bottom:1rpx solid #F0F0F0}
.oi-row:last-child{border-bottom:none}
.oi-label{font-size:26rpx;color:#999}
.oi-value{font-size:26rpx;color:#333;font-weight:500}
.service-note{font-size:22rpx;color:#BBB;text-align:center;margin-top:20rpx}
.safe-bottom{height:40rpx}
