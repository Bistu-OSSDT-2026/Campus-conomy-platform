.verify-page {
  min-height: 100vh;
  background: #F5F7FB;
  padding-bottom: 40rpx;
}

/* 顶部 */
.verify-header {
  background: linear-gradient(135deg, #2F6BFF, #4D8BFF);
  padding: 48rpx 40rpx 56rpx;
  text-align: center;
  color: #FFFFFF;
}
.header-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}
.header-desc {
  font-size: 26rpx;
  opacity: 0.85;
}

/* 表单 */
.verify-form {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: -24rpx 24rpx 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 1;
}

.form-item {
  margin-bottom: 28rpx;
}
.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}
.required {
  color: #FF4D4F;
}
.form-input {
  background: #F5F7FB;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  font-size: 28rpx;
  color: #1A1A2E;
  border: 2rpx solid transparent;
}
.form-input:focus {
  border-color: #2F6BFF;
  background: #FFFFFF;
}

.form-picker {
  background: #F5F7FB;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  font-size: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.form-picker.placeholder {
  color: #999;
}
.picker-arrow {
  font-size: 36rpx;
  color: #999;
  font-weight: 300;
}

/* 按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #2F6BFF, #4D8BFF);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.submit-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.skip-btn {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 28rpx 0;
}

/* 提示 */
.verify-tips {
  margin: 0 24rpx;
  background: #FFFBE6;
  border-radius: 16rpx;
  padding: 28rpx;
  border-left: 6rpx solid #FAAD14;
}
.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.tip-item {
  font-size: 24rpx;
  color: #666;
  line-height: 2;
}

/* ========== 学校搜索弹窗 ========== */
.school-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 500;
}
.school-picker-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 75vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 501;
  display: flex;
  flex-direction: column;
  animation: spSlideUp 0.25s ease;
}
@keyframes spSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 弹窗头部 */
.sp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
}
.sp-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A2E;
}
.sp-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

/* 搜索框 */
.sp-search-box {
  display: flex;
  align-items: center;
  margin: 0 32rpx 16rpx;
  background: #F5F7FB;
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}
.sp-search-box:focus-within {
  border-color: #2F6BFF;
  background: #FFFFFF;
}
.sp-search-icon {
  font-size: 30rpx;
  margin-right: 12rpx;
}
.sp-search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A2E;
}
.sp-clear {
  font-size: 28rpx;
  color: #CCC;
  padding: 4rpx 12rpx;
}

/* 分类标签 */
.sp-type-label {
  font-size: 24rpx;
  color: #999;
  padding: 16rpx 32rpx 8rpx;
  font-weight: 500;
}

/* 列表 */
.sp-list {
  flex: 1;
  max-height: 55vh;
}
.sp-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F5F7FB;
  transition: background 0.15s;
}
.sp-item:active {
  background: #F5F7FB;
}
.sp-item.selected {
  background: #E8F0FF;
}
.sp-item-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sp-item.selected .sp-item-name {
  color: #2F6BFF;
  font-weight: 600;
}
.sp-item-type {
  font-size: 22rpx;
  color: #2F6BFF;
  background: #E8F0FF;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}
.sp-check {
  font-size: 28rpx;
  color: #2F6BFF;
  margin-left: 12rpx;
  font-weight: 700;
}

/* 空状态 */
.sp-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.sp-empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
.sp-empty-text {
  font-size: 28rpx;
  color: #999;
}
