.reports-page {
  min-height: 100vh;
  background: #F5F7FB;
}

.reports-list {
  padding: 20rpx 24rpx;
}
.report-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.report-goods-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.report-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}
.report-status.pending {
  background: #FFFBE6;
  color: #D48806;
}
.report-status.resolved {
  background: #F6FFED;
  color: #52C41A;
}
.report-status.rejected {
  background: #FFF1F0;
  color: #FF4D4F;
}
.report-reason {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}
.report-time {
  font-size: 24rpx;
  color: #BBB;
}
.report-result {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F5F7FB;
}
.result-label {
  font-size: 24rpx;
  color: #999;
}
.result-text {
  font-size: 24rpx;
  color: #333;
}
