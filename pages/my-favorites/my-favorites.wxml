<view class="favorites-page">
  <!-- 收藏列表 -->
  <view class="goods-list" wx:if="{{goodsList.length > 0}}">
    <view class="goods-card" wx:for="{{goodsList}}" wx:key="id" bindtap="onGoodsTap" data-id="{{item.id}}">
      <image class="goods-img" src="{{item.images[0]}}" mode="aspectFill" />
      <view class="goods-info">
        <view class="goods-title">{{item.title}}</view>
        <view class="goods-cat">{{item.categoryName}}</view>
        <view class="goods-bottom">
          <view class="goods-price">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.price}}</text>
          </view>
          <view class="unfavorite-btn" catchtap="onUnfavorite" data-id="{{item.id}}">取消收藏</view>
        </view>
        <view class="seller-row">
          <image class="seller-avatar" src="{{item.seller.avatar}}" mode="aspectFill" />
          <text class="seller-name">{{item.seller.name}}</text>
          <text class="goods-time">{{item.publishTime}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{goodsList.length === 0}}">
    <text class="empty-icon">❤️</text>
    <text class="empty-text">你还没有收藏任何内容</text>
    <button class="btn-primary btn-sm" style="margin-top:30rpx" bindtap="onGoHome">去逛逛</button>
  </view>
</view>
