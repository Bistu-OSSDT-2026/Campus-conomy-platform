.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #2F6BFF 0%, #E8F0FF 50%, #F5F7FB 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-top: 120rpx;
  margin-bottom: 60rpx;
}
.logo-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.logo-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}
.logo-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
}

/* 表单区域 */
.form-section {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(47,107,255,0.15);
}

/* 登录方式切换 */
.login-tabs {
  display: flex;
  margin-bottom: 40rpx;
  border-bottom: 2rpx solid #E8ECF1;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #999;
  position: relative;
}
.tab-item.active {
  color: #2F6BFF;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2F6BFF;
  border-radius: 2rpx;
}

/* 输入框 */
.input-group {
  display: flex;
  align-items: center;
  background: #F5F7FB;
  border-radius: 48rpx;
  padding: 0 28rpx;
  margin-bottom: 24rpx;
  height: 96rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}
.input-group:focus-within {
  border-color: #2F6BFF;
  background: #FFFFFF;
}
.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}
.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A2E;
}
.eye-icon {
  font-size: 32rpx;
  padding: 10rpx;
}

/* 记住密码 */
.remember-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
}
.checkbox-wrapper {
  display: flex;
  align-items: center;
}
.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #CCCCCC;
  border-radius: 6rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
}
.checkbox.checked {
  background: #2F6BFF;
  border-color: #2F6BFF;
}
.checkbox-label {
  font-size: 26rpx;
  color: #666;
}
.forgot-pwd {
  font-size: 26rpx;
  color: #2F6BFF;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #2F6BFF, #4D8BFF);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.login-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* 注册入口 */
.register-tip {
  text-align: center;
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #999;
}
.register-link {
  color: #2F6BFF;
  font-weight: 500;
}

/* 底部说明 */
.footer-note {
  margin-top: auto;
  padding: 40rpx 0;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}
