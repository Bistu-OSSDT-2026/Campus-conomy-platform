<view class="login-page">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo-icon">🎓</view>
    <view class="logo-title">校园经济</view>
    <view class="logo-subtitle">CampusMarket · 开源校园交易平台</view>
  </view>

  <!-- ========== 登录表单 ========== -->
  <view class="form-section" wx:if="{{mode === 'login'}}">
    <!-- 登录方式切换 -->
    <view class="login-tabs">
      <view class="tab-item {{loginType === 'phone' ? 'active' : ''}}" bindtap="switchTab" data-type="phone">手机号登录</view>
      <view class="tab-item {{loginType === 'email' ? 'active' : ''}}" bindtap="switchTab" data-type="email">邮箱登录</view>
    </view>

    <!-- 手机号登录 -->
    <block wx:if="{{loginType === 'phone'}}">
      <view class="input-group">
        <view class="input-icon">📱</view>
        <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
      </view>
    </block>

    <!-- 邮箱登录 -->
    <block wx:if="{{loginType === 'email'}}">
      <view class="input-group">
        <view class="input-icon">📧</view>
        <input class="input-field" type="text" placeholder="请输入邮箱地址" value="{{email}}" bindinput="onEmailInput" />
      </view>
    </block>

    <!-- 密码 -->
    <view class="input-group">
      <view class="input-icon">🔒</view>
      <input class="input-field" type="{{showPassword ? 'text' : 'password'}}" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
      <view class="eye-icon" bindtap="togglePassword">
        {{showPassword ? '👁️' : '👁️‍🗨️'}}
      </view>
    </view>

    <!-- 记住密码 -->
    <view class="remember-row">
      <view class="checkbox-wrapper" bindtap="toggleRemember">
        <view class="checkbox {{rememberPwd ? 'checked' : ''}}">
          <text wx:if="{{rememberPwd}}">✓</text>
        </view>
        <text class="checkbox-label">记住密码</text>
      </view>
      <text class="forgot-pwd" bindtap="onForgotPwd">忘记密码?</text>
    </view>

    <!-- 登录按钮 -->
    <button class="login-btn" bindtap="onLogin" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '登录中...' : '登 录'}}
    </button>

    <!-- 注册入口 -->
    <view class="register-tip">
      还没有账号？<text class="register-link" bindtap="onGoRegister">立即注册</text>
    </view>
  </view>

  <!-- ========== 注册表单 ========== -->
  <view class="form-section" wx:if="{{mode === 'register'}}">
    <!-- 注册方式切换 -->
    <view class="login-tabs">
      <view class="tab-item {{loginType === 'phone' ? 'active' : ''}}" bindtap="switchTab" data-type="phone">手机号注册</view>
      <view class="tab-item {{loginType === 'email' ? 'active' : ''}}" bindtap="switchTab" data-type="email">邮箱注册</view>
    </view>

    <!-- 昵称 -->
    <view class="input-group">
      <view class="input-icon">😊</view>
      <input class="input-field" type="text" maxlength="12" placeholder="请输入昵称（2-12个字符）" value="{{nickname}}" bindinput="onNicknameInput" />
    </view>

    <!-- 手机号 -->
    <block wx:if="{{loginType === 'phone'}}">
      <view class="input-group">
        <view class="input-icon">📱</view>
        <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
      </view>
    </block>

    <!-- 邮箱 -->
    <block wx:if="{{loginType === 'email'}}">
      <view class="input-group">
        <view class="input-icon">📧</view>
        <input class="input-field" type="text" placeholder="请输入邮箱地址" value="{{email}}" bindinput="onEmailInput" />
      </view>
    </block>

    <!-- 密码 -->
    <view class="input-group">
      <view class="input-icon">🔒</view>
      <input class="input-field" type="{{showPassword ? 'text' : 'password'}}" placeholder="请输入密码（至少6位）" value="{{password}}" bindinput="onPasswordInput" />
      <view class="eye-icon" bindtap="togglePassword">
        {{showPassword ? '👁️' : '👁️‍🗨️'}}
      </view>
    </view>

    <!-- 确认密码 -->
    <view class="input-group">
      <view class="input-icon">🔒</view>
      <input class="input-field" type="{{showConfirmPassword ? 'text' : 'password'}}" placeholder="请再次确认密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      <view class="eye-icon" bindtap="toggleConfirmPassword">
        {{showConfirmPassword ? '👁️' : '👁️‍🗨️'}}
      </view>
    </view>

    <!-- 注册按钮 -->
    <button class="login-btn" bindtap="onRegister" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '注册中...' : '注 册'}}
    </button>

    <!-- 返回登录入口 -->
    <view class="register-tip">
      已有账号？<text class="register-link" bindtap="switchMode" data-mode="login">立即登录</text>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="footer-note">
    <text>开源协议 AGPL-3.0 | 校园专属平台</text>
  </view>
</view>
