.admin-page {
  min-height: 100vh;
  background: #F5F7FB;
  padding-bottom: 40rpx;
}

/* 无权限 */
.no-permission {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 48rpx;
  text-align: center;
}
.np-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}
.np-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 12rpx;
}
.np-desc {
  font-size: 28rpx;
  color: #999;
}

/* 数据概览 */
.overview-section {
  padding: 24rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 20rpx;
}
.overview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.overview-card {
  width: calc(50% - 8rpx);
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.ov-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #2F6BFF;
  display: block;
  margin-bottom: 8rpx;
}
.ov-num.warning { color: #FAAD14; }
.ov-num.success { color: #52C41A; }
.ov-label {
  font-size: 24rpx;
  color: #999;
}

/* Tab */
.admin-tabs {
  display: flex;
  background: #FFFFFF;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}
.tab.active {
  color: #2F6BFF;
  font-weight: 600;
  border-bottom-color: #2F6BFF;
}

/* 商品管理 */
.tab-content {
  padding: 20rpx 24rpx;
}
.goods-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.gi-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.gi-info {
  flex: 1;
  overflow: hidden;
}
.gi-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}
.gi-seller {
  font-size: 22rpx;
  color: #999;
}
.gi-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 12rpx;
}
.gi-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
}
.gi-status.online { background: #F6FFED; color: #52C41A; }
.gi-status.offline { background: #F5F5F5; color: #999; }
.gi-btn {
  font-size: 22rpx;
  color: #2F6BFF;
  padding: 6rpx 16rpx;
  background: #E8F0FF;
  border-radius: 8rpx;
}
.gi-btn.danger {
  color: #FF4D4F;
  background: #FFF1F0;
}

/* 举报 */
.report-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.ri-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.ri-reason {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.ri-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}
.ri-status.pending { background: #FFFBE6; color: #D48806; }
.ri-status.resolved { background: #F6FFED; color: #52C41A; }
.ri-info {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}
.ri-actions {
  display: flex;
  gap: 12rpx;
}
.ri-btn {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  padding: 14rpx 0;
  border-radius: 12rpx;
  background: #E8F0FF;
  color: #2F6BFF;
}
.ri-btn.danger {
  background: #FFF1F0;
  color: #FF4D4F;
}
