.page{background:#F5F7FB;min-height:100vh;padding:20rpx 24rpx}
.card{background:#FFF;border-radius:24rpx;padding:24rpx;margin-bottom:20rpx}
.card-title{font-size:28rpx;font-weight:600;color:#1A1A2E;margin-bottom:16rpx}
.type-grid{display:flex;flex-wrap:wrap;gap:12rpx}
.type-item{width:calc(33.33% - 8rpx);display:flex;flex-direction:column;align-items:center;padding:20rpx 0;border-radius:16rpx;background:#F5F7FB}
.type-item.active{background:#F0F5FF;border:2rpx solid #2F6BFF}
.type-icon{font-size:36rpx;margin-bottom:8rpx}
.type-name{font-size:24rpx;color:#555}
.form-input{background:#F5F7FB;border-radius:16rpx;padding:20rpx 24rpx;font-size:28rpx;margin-bottom:16rpx}
.form-textarea{background:#F5F7FB;border-radius:16rpx;padding:20rpx 24rpx;font-size:28rpx;height:140rpx;margin-bottom:8rpx}
.img-list{display:flex;flex-wrap:wrap;gap:16rpx}
.img-item{width:160rpx;height:160rpx;border-radius:16rpx;position:relative;overflow:hidden}
.img-thumb{width:100%;height:100%}
.img-remove{position:absolute;top:0;right:0;background:rgba(0,0,0,0.5);color:#FFF;width:36rpx;height:36rpx;display:flex;align-items:center;justify-content:center;font-size:22rpx;border-radius:0 12rpx 0 12rpx}
.img-add{width:160rpx;height:160rpx;border-radius:16rpx;border:2rpx dashed #DDD;display:flex;align-items:center;justify-content:center;font-size:48rpx;color:#CCC}
.btn-primary{width:100%;background:linear-gradient(135deg,#4A6CF7,#2F6BFF);color:#FFF;border-radius:16rpx;font-size:30rpx;font-weight:600;padding:24rpx 0;border:none}
.btn-primary::after{border:none}
.result-card{background:#FFF;border-radius:24rpx;padding:40rpx 32rpx;text-align:center}
.result-icon{font-size:80rpx;margin-bottom:16rpx}
.result-title{font-size:34rpx;font-weight:700;color:#2E7D32;margin-bottom:8rpx}
.result-sub{font-size:26rpx;color:#666;margin-bottom:24rpx}
.repair-info{text-align:left;background:#F9FAFB;border-radius:16rpx;padding:20rpx}
.ri-row{display:flex;justify-content:space-between;padding:12rpx 0;border-bottom:1rpx solid #F0F0F0}
.ri-row:last-child{border-bottom:none}
.ri-label{font-size:26rpx;color:#999}
.ri-value{font-size:26rpx;color:#333;font-weight:500}
.service-note{font-size:22rpx;color:#BBB;text-align:center;margin-top:20rpx}
.safe-bottom{height:40rpx}
