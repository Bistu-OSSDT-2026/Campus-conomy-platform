.page { background: #F5F7FB; min-height: 100vh; padding: 20rpx 24rpx; }
.card { background: #FFF; border-radius: 24rpx; padding: 24rpx; margin-bottom: 20rpx; }
.card-title { font-size: 28rpx; font-weight: 600; color: #1A1A2E; margin-bottom: 16rpx; }
.picker-box { background: #F5F7FB; border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #333; }
.tag-row { display: flex; gap: 16rpx; }
.tag-row.wrap { flex-wrap: wrap; }
.tag { padding: 14rpx 24rpx; border-radius: 12rpx; font-size: 26rpx; color: #666; background: #F5F7FB; }
.tag.active { background: #2F6BFF; color: #FFF; }
.seat-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.seat { width: calc(20% - 10rpx); height: 70rpx; display: flex; align-items: center; justify-content: center; border-radius: 12rpx; font-size: 24rpx; background: #F5F7FB; color: #999; }
.seat.available { background: #E8F5E9; color: #2E7D32; }
.seat.booked { background: #FFEBEE; color: #C62828; }
.seat.maintenance { background: #F5F5F5; color: #BDBDBD; }
.seat.selected { border: 3rpx solid #2F6BFF; color: #2F6BFF; font-weight: 700; }
.seat-legend { display: flex; align-items: center; gap: 10rpx; margin-top: 16rpx; font-size: 22rpx; color: #999; }
.legend-dot { width: 20rpx; height: 20rpx; border-radius: 6rpx; }
.legend-dot.available { background: #E8F5E9; }
.legend-dot.booked { background: #FFEBEE; }
.legend-dot.maintenance { background: #F5F5F5; }
.btn-primary { width: 100%; background: linear-gradient(135deg, #4A6CF7, #2F6BFF); color: #FFF; border-radius: 16rpx; font-size: 30rpx; font-weight: 600; padding: 24rpx 0; border: none; }
.btn-primary::after { border: none; }
.result-card { text-align: center; }
.result-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.result-title { font-size: 34rpx; font-weight: 700; color: #2E7D32; margin-bottom: 8rpx; }
.result-tip { font-size: 26rpx; color: #666; margin-bottom: 24rpx; }
.result-info { text-align: left; background: #F9FAFB; border-radius: 16rpx; padding: 20rpx; }
.result-info .info-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.result-info .info-row:last-child { border-bottom: none; }
.result-info .label { color: #999; font-size: 26rpx; }
.result-info .value { color: #333; font-size: 26rpx; font-weight: 500; }
.service-note { font-size: 22rpx; color: #BBB; margin-top: 20rpx; text-align: center; }
.safe-bottom { height: 40rpx; }
