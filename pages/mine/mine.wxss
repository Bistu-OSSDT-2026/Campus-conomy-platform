.mine-page {
  min-height: 100vh;
  background: #F5F7FB;
}

/* 未登录 */
.not-login {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 48rpx;
  text-align: center;
}
.nl-avatar {
  width: 120rpx;
  height: 120rpx;
  background: #E8F0FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 24rpx;
}
.nl-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 12rpx;
}
.nl-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
}
.nl-btn {
  width: 320rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #2F6BFF, #4D8BFF);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #2F6BFF, #4D8BFF);
  padding: 40rpx 32rpx 36rpx;
  position: relative;
  overflow: hidden;
}
.user-bg {
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}
.user-info {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}
.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.4);
  margin-right: 24rpx;
}
.user-detail {
  flex: 1;
}
.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}
.verified-badge {
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(82,196,26,0.8);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 10rpx;
  font-weight: 400;
}
.user-school {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}
.go-verify {
  color: #FFD43B;
  font-weight: 500;
}
.user-edit {
  color: #FFFFFF;
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
  border-radius: 48rpx;
}

/* 统计 */
.stats-card {
  background: #FFFFFF;
  margin: -16rpx 24rpx 16rpx;
  border-radius: 24rpx;
  padding: 28rpx 0;
  display: flex;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 1;
}
.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #F5F7FB;
}
.stat-item:last-child {
  border-right: none;
}
.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #2F6BFF;
  display: block;
  margin-bottom: 6rpx;
}
.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 菜单 */
.menu-section {
  padding: 0 24rpx;
}
.menu-group {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.menu-group-title {
  font-size: 26rpx;
  color: #999;
  padding: 20rpx 28rpx 8rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #F5F7FB;
  transition: background 0.2s;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-item:active {
  background: #F5F7FB;
}
.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}
.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.menu-badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}
.menu-badge.pending {
  background: #FFFBE6;
  color: #D48806;
}
.menu-arrow {
  font-size: 32rpx;
  color: #CCC;
  font-weight: 300;
}

/* 退出 */
.logout-section {
  padding: 40rpx 24rpx;
}
.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  color: #FF4D4F;
  border-radius: 48rpx;
  font-size: 30rpx;
  border: 2rpx solid #FFE0E0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.logout-btn:active {
  background: #FFF1F0;
}
