<view class="mine-page">
  <!-- 未登录 -->
  <view class="not-login" wx:if="{{!isLoggedIn}}">
    <view class="nl-avatar">👤</view>
    <view class="nl-title">登录后查看更多</view>
    <view class="nl-desc">登录后可管理发布、收藏和订单</view>
    <button class="nl-btn" bindtap="onGoLogin">登录 / 注册</button>
  </view>

  <!-- 已登录 -->
  <block wx:else>
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-bg"></view>
      <view class="user-info">
        <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
        <view class="user-detail">
          <view class="user-name">
            {{userInfo.nickname}}
            <text class="verified-badge" wx:if="{{userInfo.verified}}">✓已认证</text>
          </view>
          <view class="user-school" wx:if="{{userInfo.school}}">{{userInfo.school}} · {{userInfo.campus}} · {{userInfo.grade}}</view>
          <view class="user-school" wx:elif="{{userInfo.nickname}}">{{userInfo.major || ''}}{{userInfo.grade ? ' · ' + userInfo.grade : ''}}</view>
          <view class="user-school" wx:else>未认证 <text class="go-verify" bindtap="onGoVerify">去认证 ›</text></view>
        </view>
        <view class="user-edit" bindtap="onGoSettings">编辑</view>
      </view>
    </view>

    <!-- 数据统计 -->
    <view class="stats-card">
      <view class="stat-item" bindtap="onGoMyPosts">
        <text class="stat-num">{{myPostsCount}}</text>
        <text class="stat-label">我的发布</text>
      </view>
      <view class="stat-item" bindtap="onGoMyOrders">
        <text class="stat-num">{{myOrdersCount}}</text>
        <text class="stat-label">我的订单</text>
      </view>
      <view class="stat-item" bindtap="onGoMyFavorites">
        <text class="stat-num">{{favoritesCount}}</text>
        <text class="stat-label">我的收藏</text>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-group">
        <view class="menu-item" bindtap="onGoMyPosts">
          <text class="menu-icon">📦</text>
          <text class="menu-text">我的发布</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onGoMyOrders">
          <text class="menu-icon">📋</text>
          <text class="menu-text">我的订单</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onGoMyFavorites">
          <text class="menu-icon">❤️</text>
          <text class="menu-text">我的收藏</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onGoVerify" wx:if="{{!userInfo.verified}}">
          <text class="menu-icon">🛡️</text>
          <text class="menu-text">校园认证</text>
          <text class="menu-badge pending">待认证</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <view class="menu-group">
        <view class="menu-item" bindtap="onGoReports">
          <text class="menu-icon">🚨</text>
          <text class="menu-text">我的举报</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onGoSettings">
          <text class="menu-icon">⚙️</text>
          <text class="menu-text">账号与隐私设置</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onGoAgreement">
          <text class="menu-icon">📄</text>
          <text class="menu-text">用户协议</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <view class="menu-group">
        <view class="menu-item" bindtap="onAbout">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-text">关于校园经济</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onGoOpensource">
          <text class="menu-icon">📖</text>
          <text class="menu-text">开源说明</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onFeedback">
          <text class="menu-icon">💬</text>
          <text class="menu-text">意见反馈</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <!-- 管理员入口 -->
      <view class="menu-group" wx:if="{{isAdmin}}">
        <view class="menu-group-title">管理员</view>
        <view class="menu-item" bindtap="onGoAdmin">
          <text class="menu-icon">⚙️</text>
          <text class="menu-text">管理后台</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <button class="logout-btn" bindtap="onLogout">退出登录</button>
    </view>
  </block>

  <view class="safe-bottom"></view>
</view>
